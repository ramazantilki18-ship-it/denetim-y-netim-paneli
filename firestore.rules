rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function userExists() {
      return isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function userRole() {
      return userExists() ? userDoc().data.role : '';
    }

    function userRoleId() {
      return userExists() ? userDoc().data.roleId : '';
    }

    function isAdmin() {
      return userExists()
        && (
          userRole() in ['admin', 'Super_Admin']
          || userRoleId() == 'Super_Admin'
        );
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && (isOwner(userId) || isAdmin());
      allow update: if isAdmin() || isOwner(userId);
      allow delete: if isAdmin();
    }

    match /audits/{auditId} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn();
      allow delete: if isAdmin();
    }

    match /nonconformities/{ncId} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn();
      allow delete: if isAdmin();
    }

    match /question_groups/{groupId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    match /questions/{questionId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    match /plans/{planId} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn();
      allow delete: if isAdmin();
    }

    match /announcements/{announcementId} {
      allow read: if isSignedIn();
      allow create, update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /system_config/{docId} {
      allow read: if isSignedIn();
      allow create, delete: if isAdmin();
      allow update: if isAdmin() && (
        docId != 'lines_stations' || (
          (!request.resource.data.keys().hasAll(['stationLocations']) || request.resource.data.stationLocations.size() >= resource.data.stationLocations.size()) &&
          (!request.resource.data.keys().hasAll(['stations']) || request.resource.data.stations.size() >= resource.data.stations.size())
        )
      );
    }

    match /reports/{reportId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isSignedIn();
    }

    match /auditReports/{reportId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isSignedIn();
    }

    match /auditResponses/{responseId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isSignedIn();
    }

    match /auditTypes/{typeId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    match /auditQuestionGroups/{groupId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    match /auditQuestions/{questionId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    match /shifts/{shiftId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    match /user_rosters/{rosterId} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn();
      allow delete: if isAdmin();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
